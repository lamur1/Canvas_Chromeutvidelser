{
  "manifest_version": 3,
  "name": "Canvas – Sett inn mal",
  "version": "1.0",
  "description": "Henter mal fra din Canvasside og setter den inn i Speed Grader.",
  "permissions": ["activeTab", "scripting", "commands", "storage"],
  "host_permissions": ["https://*.instructure.com/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_icon": { "16": "icon16.png", "48": "icon48.png" } },
  "commands": {
    "sett-inn-mal": {
      "suggested_key": { "default": "Ctrl+Shift+M", "mac": "Command+Shift+M" },
      "description": "Sett inn mal fra Canvasside"
    }
  },
  "icons": { "16": "icon16.png", "48": "icon48.png" }
}
